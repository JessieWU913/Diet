# =========================
# 核心机密文件 (绝不能上传)
# =========================
.env
.env.*
*.pem
*.key
*.log
.cache/
.secret_config

# =========================
# Backend (Django / Python)
# =========================
# 字节码和缓存
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# 虚拟环境 (极其庞大，千万别传)
venv/
.venv/
env/
.env_dir/

# 数据库文件
db.sqlite3
db.sqlite3-journal

# 静态文件和上传资源
diet_agent_backend/media/
diet_agent_backend/staticfiles/

# =========================
# Frontend (Vue / Node.js)
# =========================
# 依赖包 (极其庞大)
node_modules/
diet_agent_frontend/node_modules/

# 打包输出目录
dist/
dist-ssr/
diet_agent_frontend/dist/

# Vite 缓存
.vite/

# 日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

